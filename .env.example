# Copy this file to .env and fill in values before running docker-compose
# Do NOT commit .env with secrets to version control.

# Soroban RPC endpoint (testnet)
CONS_SOROBAN_RPC=https://soroban-testnet.stellar.org

# Deployed contract ID returned by `soroban contract deploy`
CONS_CONTRACT_ID=REPLACE_WITH_CONTRACT_ID

# Signer secret seed for SDK-based signing (keep this secret)
CONS_SIGNER_SECRET=

# Optional admin token to protect the /admin/set_contract endpoint (dev-only)
ADMIN_TOKEN=
